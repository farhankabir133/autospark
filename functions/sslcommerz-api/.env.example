# Auto Spark - SSLCommerz Payment Gateway Integration
# Environment Variables Configuration
# 
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file with real credentials

# ============================================
# SSLCommerz Configuration (LIVE)
# ============================================
# Store ID provided by SSLCommerz
SSLCZ_STORE_ID=autosparkbd0live

# Store password provided by SSLCommerz
SSLCZ_STORE_PASSWD=69DBB19BAB55E48107

# ============================================
# Appwrite Cloud Configuration
# ============================================
# Appwrite Cloud Endpoint (Asia region in this case)
APPWRITE_API_ENDPOINT=https://sgp.cloud.appwrite.io/v1

# Appwrite API Key (with admin permissions)
APPWRITE_API_KEY=your_appwrite_api_key_here

# Appwrite Project ID
APPWRITE_PROJECT_ID=69d09ead0018cd1663a7

# Appwrite Database ID for orders collection
APPWRITE_ORDERS_DATABASE_ID=orders_db

# Appwrite Collection ID for orders documents
APPWRITE_ORDERS_COLLECTION_ID=orders_collection

# ============================================
# Auto Spark Configuration
# ============================================
# Base domain URL for Auto Spark
BASE_URL=https://autosparkbd.com

# Frontend custom domain for browser redirects after gateway callback
FRONTEND_BASE_URL=https://autosparkbd.com

# Appwrite Function Execution Endpoint used by SSLCommerz callbacks
# Example: https://sgp.cloud.appwrite.io/v1/functions/sslcommerz-api/executions
FUNCTION_EXECUTION_ENDPOINT=https://sgp.cloud.appwrite.io/v1/functions/sslcommerz-api/executions

# CORS Origin for payment requests (browser requests)
CORS_ORIGIN=https://autosparkbd.com

# ============================================
# Environment Settings
# ============================================
# Set to 'production' or 'development'
NODE_ENV=production

# Enable debug logging (true/false)
DEBUG=false
