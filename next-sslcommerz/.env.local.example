# Copy this file to .env.local and replace with your credentials. Do NOT commit .env.local with secrets.

# SSLCommerz Configuration
STORE_ID=your_store_id_here
STORE_PASS=your_store_pass_here
IS_LIVE=false

# The public base URL of your app (used to build success/fail/cancel URLs)
APP_URL=http://localhost:3000

# Supabase Configuration (for order management)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Example values (do not commit these into public repo):
# STORE_ID=autos69cccc023b067
# STORE_PASS=autos69cccc023b067@ssl
# IS_LIVE=false
# SUPABASE_URL=https://hcdwfxnvmvvkbpeshbqk.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_o4V4NsBTa1omeSCyl8GuuA_UppA17sl
