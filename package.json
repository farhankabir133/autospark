{
  "name": "autospark",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://autosparkbd.com",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "audit:pa11y": "npx pa11y http://127.0.0.1:4173 --standard wcag2aa --timeout 20000 > pa11y-report.txt",
    "audit:lighthouse": "npx lighthouse http://127.0.0.1:4173 --only-categories=performance,accessibility,best-practices,seo --output=json --output-path=lh-report.json --chrome-flags='--headless'",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "proxy": "node server/proxy.cjs",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google/model-viewer": "^3.5.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^9.109.2",
    "@react-three/fiber": "^8.16.8",
    "@supabase/supabase-js": "^2.101.1",
    "@types/three": "^0.163.0",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^1.3.0",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.13.1",
    "rehype-sanitize": "^5.0.1",
    "remark-gfm": "^3.0.1",
    "three": "~0.163.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.35.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "express": "^4.18.2",
    "gh-pages": "^6.3.0",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "rollup-plugin-visualizer": "^5.9.1",
    "supabase": "^2.84.6",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^1.1.5"
