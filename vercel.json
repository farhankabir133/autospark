{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs24.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/:match*"
    }
  ],
  "env": {
    "SSLCOMMERZ_STORE_ID": "@sslcommerz_store_id",
    "SSLCOMMERZ_STORE_PASSWORD": "@sslcommerz_store_password",
    "STORE_ID": "@store_id",
    "STORE_PASS": "@store_pass",
    "SITE_URL": "@site_url"
  }
}
